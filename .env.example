# LLM Configuration (choose your provider and uncomment)
# OPENROUTER_API_KEY="..."
# GEMINI_API_KEY="..."
# OPENAI_API_KEY="sk-..."
# ANTHROPIC_API_KEY="sk-..."

# LiteLLM model names (update if you want to use different models)
LITELLM_MODEL="openrouter/minimax/minimax-m2"
LITELLM_IMAGE_MODEL="gemini/imagen-4.0-generate-001"

# Cloudflare Configuration (required for --publish and --preview)
CLOUDFLARE_API_TOKEN="your-cloudflare-api-token"
CLOUDFLARE_ACCOUNT_ID="your-cloudflare-account-id"

# The name of your Cloudflare Pages project
PROJECT_NAME="my-website-project"
